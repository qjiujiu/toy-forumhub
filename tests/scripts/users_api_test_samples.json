{
  "version": "1.0",
  "description": "app/api/v2/users.py 所有接口的真实测试样例",
  "base_url": "http://localhost:8000",
  "endpoints": [
    {
      "method": "POST",
      "path": "/users/",
      "summary": "创建用户（注册）",
      "cases": [
        {
          "scenario": "成功创建用户",
          "request": {
            "body": {
              "username": "张三",
              "password": "Abc@123456",
              "phone": "13800138001"
            }
          },
          "expected_response": {
            "code": 200,
            "msg": "success",
            "data": {
              "uid": "a1b2c3d4-e5f6-7890-abcd-ef1234567890",
              "user_info": {
                "username": "张三",
                "phone": "13800138001",
                "email": null,
                "avatar_url": null,
                "bio": null,
                "role": 0,
                "status": 0
              },
              "user_data": {
                "last_login_at": "2026-05-12T10:30:00",
                "created_at": "2026-05-12T10:30:00",
                "updated_at": "2026-05-12T10:30:00",
                "deleted_at": null
              }
            }
          }
        },
        {
          "scenario": "手机号已注册（重复phone）",
          "request": {
            "body": {
              "username": "李四",
              "password": "Abc@123456",
              "phone": "13800138001"
            }
          },
          "expected_response": {
            "code": 500,
            "msg": "(pymysql.err.IntegrityError) (1062, \"Duplicate entry '13800138001' for key 'users.phone'\")",
            "data": null
          }
        },
        {
          "scenario": "缺少必填字段username",
          "request": {
            "body": {
              "password": "Abc@123456",
              "phone": "13800138002"
            }
          },
          "expected_response": {
            "detail": [
              {
                "loc": ["body", "username"],
                "msg": "field required",
                "type": "value_error.missing"
              }
            ]
          }
        }
      ]
    },
    {
