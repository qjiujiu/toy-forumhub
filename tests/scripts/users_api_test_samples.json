    {
      "method": "PUT",
      "path": "/users/info/id/{uid}",
      "summary": "普通用户更新自己的信息",
      "cases": [
        {
          "scenario": "成功更新用户昵称和头像",
          "request": {
            "path_params": {
              "uid": "a1b2c3d4-e5f6-7890-abcd-ef1234567890"
            },
            "body": {
              "username": "张三（改名了）",
              "avatar_url": "https://example.com/avatars/new_avatar.png",
              "bio": "这是新的个人简介"
            }
          },
          "expected_response": {
            "code": 200,
            "msg": "success",
            "data": {
              "uid": "a1b2c3d4-e5f6-7890-abcd-ef1234567890",
              "user_info": {
                "username": "张三（改名了）",
                "phone": "13800138001",
                "email": null,
                "avatar_url": "https://example.com/avatars/new_avatar.png",
                "bio": "这是新的个人简介",
                "role": 0,
                "status": 0
              },
              "user_data": {
                "last_login_at": "2026-05-12T10:30:00",
                "created_at": "2026-05-12T10:30:00",
                "updated_at": "2026-05-12T14:00:00",
                "deleted_at": null
              }
            }
          }
        },
        {
          "scenario": "更新不存在的用户",
          "request": {
            "path_params": {
              "uid": "eeeeeeee-ffff-0000-1111-222222222222"
            },
            "body": {
              "username": "路人甲"
            }
          },
          "expected_response": {
            "code": 404,
            "msg": "uid eeeeeeee-ffff-0000-1111-222222222222 not found.",
            "data": null
          }
        },
        {
          "scenario": "更新用户时传入不允许的字段（role）应被拒绝",
          "request": {
            "path_params": {
              "uid": "a1b2c3d4-e5f6-7890-abcd-ef1234567890"
            },
            "body": {
              "username": "张三",
              "role": 2
            }
          },
          "expected_response": {
            "code": 422,
            "detail": [
              {
                "loc": ["body", "role"],
                "msg": "extra fields not permitted",
                "type": "value_error.extra"
              }
            ]
          }
        }
      ]
    },
    {
      "method": "PUT",
      "path": "/users/password/id/{uid}",
      "summary": "修改密码",
      "cases": [
        {
          "scenario": "成功修改密码（已知旧密码）",
          "request": {
            "path_params": {
              "uid": "a1b2c3d4-e5f6-7890-abcd-ef1234567890"
            },
            "body": {
              "old_password": "Abc@123456",
              "new_password": "NewPwd@789"
            }
          },
          "expected_response": {
            "code": 200,
            "msg": "success",
            "data": true
          }
        },
        {
          "scenario": "旧密码错误",
          "request": {
            "path_params": {
              "uid": "a1b2c3d4-e5f6-7890-abcd-ef1234567890"
            },
            "body": {
              "old_password": "wrong_password",
              "new_password": "NewPwd@789"
            }
          },
          "expected_response": {
            "code": 400,
            "msg": "old password mismatch",
            "data": null
          }
        },
        {
          "scenario": "用户不存在时修改密码",
          "request": {
            "path_params": {
              "uid": "eeeeeeee-ffff-0000-1111-222222222222"
            },
            "body": {
              "old_password": "Abc@123456",
              "new_password": "NewPwd@789"
            }
          },
          "expected_response": {
            "code": 404,
            "msg": "uid eeeeeeee-ffff-0000-1111-222222222222 not found.",
            "data": null
          }
        }
      ]
    },
    {
      "method": "DELETE",
      "path": "/users/soft/id/{uid}",
      "summary": "软删除用户（注销）",
      "cases": [
        {
          "scenario": "成功软删除用户",
          "request": {
            "path_params": {
              "uid": "a1b2c3d4-e5f6-7890-abcd-ef1234567890"
            }
          },
          "expected_response": {
            "code": 200,
            "msg": "success",
            "data": true
          }
        },
        {
          "scenario": "软删除不存在的用户",
          "request": {
            "path_params": {
              "uid": "eeeeeeee-ffff-0000-1111-222222222222"
            }
          },
          "expected_response": {
            "code": 404,
            "msg": "soft delete faliled",
            "data": false
          }
        },
        {
          "scenario": "重复软删除（已删除的用户再次软删除）",
          "request": {
            "path_params": {
              "uid": "dddddddd-cccc-bbbb-aaaa-999999999999"
            }
          },
          "expected_response": {
            "code": 404,
            "msg": "uid dddddddd-cccc-bbbb-aaaa-999999999999 not found.",
            "data": null
          }
        }
      ]
    },
    {
      "method": "DELETE",
      "path": "/users/hard",
      "summary": "管理员硬删除用户",
      "cases": [
        {
          "scenario": "管理员成功硬删除用户",
          "request": {
            "body": {
              "admin_uid": "f0000000-0000-0000-0000-000000000001",
              "user_uid": "b2c3d4e5-f6a7-8901-bcde-f12345678901"
            }
          },
          "expected_response": {
            "code": 200,
            "msg": "success",
            "data": true
          }
        },
        {
          "scenario": "非管理员尝试硬删除（权限不足）",
          "request": {
            "body": {
              "admin_uid": "a1b2c3d4-e5f6-7890-abcd-ef1234567890",
              "user_uid": "b2c3d4e5-f6a7-8901-bcde-f12345678901"
            }
          },
          "expected_response": {
            "code": 403,
            "msg": "admin permission denied",
            "data": null
          }
        },
        {
          "scenario": "管理员硬删除不存在的用户",
          "request": {
            "body": {
              "admin_uid": "f0000000-0000-0000-0000-000000000001",
              "user_uid": "eeeeeeee-ffff-0000-1111-222222222222"
            }
          },
          "expected_response": {
            "code": 404,
            "msg": "hard delete failed",
            "data": false
          }
        }
      ]
    },
