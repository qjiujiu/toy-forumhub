{
  "version": "1.0",
  "description": "app/api/v2/comments.py 所有接口的真实测试样例",
  "base_url": "http://localhost:8000",
  "endpoints": [
    {
      "method": "POST",
      "path": "/comments/",
      "summary": "创建评论",
      "cases": [
        {
          "scenario": "成功创建一级评论（无 parent_id/root_id）",
          "request": {
            "body": {
              "post_id": "p0000001-0000-0000-0000-000000000001",
              "author_id": "221d559c-c349-497b-a40e-362717e0d1b5",
              "content": "好帖子，支持一下！"
            }
          },
          "expected_response": {
            "code": 200,
            "msg": "success",
            "data": {
              "cid": "c0000001-0000-0000-0000-000000000001",
              "post_id": "p0000001-0000-0000-0000-000000000001",
              "author_id": "221d559c-c349-497b-a40e-362717e0d1b5",
              "comment_content": {
                "ccid": "cc000001-0000-0000-0000-000000000001",
                "comment_id": "c0000001-0000-0000-0000-000000000001",
                "content": "好帖子，支持一下！",
                "created_at": "2026-05-12T14:00:00",
                "updated_at": "2026-05-12T14:00:00"
              },
              "parent_id": null,
              "root_id": null,
              "comment_count": 0,
              "like_count": 0,
              "status": 0,
              "review_status": 0,
              "reviewed_at": null,
              "deleted_at": null
            }
          }
        },
        {
          "scenario": "成功创建楼中楼回复（带 parent_id/root_id）",
          "request": {
            "body": {
              "post_id": "p0000001-0000-0000-0000-000000000001",
              "author_id": "b2c3d4e5-f6a7-8901-bcde-f12345678901",
              "content": "同意楼上，确实不错",
              "parent_id": "c0000001-0000-0000-0000-000000000001",
              "root_id": "c0000001-0000-0000-0000-000000000001"
            }
          },
          "expected_response": {
            "code": 200,
            "msg": "success",
            "data": {
              "cid": "c0000002-0000-0000-0000-000000000002",
              "post_id": "p0000001-0000-0000-0000-000000000001",
              "author_id": "b2c3d4e5-f6a7-8901-bcde-f12345678901",
              "comment_content": {
                "ccid": "cc000002-0000-0000-0000-000000000002",
                "comment_id": "c0000002-0000-0000-0000-000000000002",
                "content": "同意楼上，确实不错",
                "created_at": "2026-05-12T14:05:00",
                "updated_at": "2026-05-12T14:05:00"
              },
              "parent_id": "c0000001-0000-0000-0000-000000000001",
              "root_id": "c0000001-0000-0000-0000-000000000001",
              "comment_count": 0,
              "like_count": 0,
              "status": 0,
              "review_status": 0,
              "reviewed_at": null,
              "deleted_at": null
            }
          }
        },
        {
          "scenario": "创建评论时缺少必填字段（空 content）",
          "request": {
            "body": {
              "post_id": "p0000001-0000-0000-0000-000000000001",
              "author_id": "221d559c-c349-497b-a40e-362717e0d1b5",
              "content": ""
            }
          },
          "expected_response": {
            "code": 422,
            "detail": [
              {
                "loc": ["body", "content"],
                "msg": "Value error, Content cannot be empty",
                "type": "value_error"
              }
            ]
          }
        },
        {
          "scenario": "给不存在的帖子创建评论",
          "request": {
            "body": {
              "post_id": "p9999999-9999-9999-9999-999999999999",
              "author_id": "221d559c-c349-497b-a40e-362717e0d1b5",
              "content": "这是一条评论"
            }
          },
          "expected_response": {
            "code": 500,
            "msg": "post p9999999-9999-9999-9999-999999999999 not found.",
            "data": null
          }
        }
      ]
    },
