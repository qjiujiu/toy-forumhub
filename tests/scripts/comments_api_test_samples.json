    {
      "method": "PATCH",
      "path": "/comments/id/{cid}",
      "summary": "审核员/管理员更新评论状态（折叠/审核）",
      "cases": [
        {
          "scenario": "管理员成功将评论折叠（status → FOLDED=1）",
          "request": {
            "path_params": {
              "cid": "c0000001-0000-0000-0000-000000000001"
            },
            "query_params": {
              "admin_uid": "f0000000-0000-0000-0000-000000000001"
            },
            "body": {
              "status": 1
            }
          },
          "expected_response": {
            "code": 200,
            "msg": "success",
            "data": true
          }
        },
        {
          "scenario": "非管理员尝试更新评论状态（权限不足）",
          "request": {
            "path_params": {
              "cid": "c0000001-0000-0000-0000-000000000001"
            },
            "query_params": {
              "admin_uid": "b2c3d4e5-f6a7-8901-bcde-f12345678901"
            },
            "body": {
              "status": 1
            }
          },
          "expected_response": {
            "code": 403,
            "msg": "admin permission denied",
            "data": null
          }
        },
        {
          "scenario": "管理员审核拒绝评论（review_status → REJECTED=1）",
          "request": {
            "path_params": {
              "cid": "c0000002-0000-0000-0000-000000000002"
            },
            "query_params": {
              "admin_uid": "f0000000-0000-0000-0000-000000000001"
            },
            "body": {
              "review_status": 1
            }
          },
          "expected_response": {
            "code": 200,
            "msg": "success",
            "data": true
          }
        },
        {
          "scenario": "更新不存在的评论状态",
          "request": {
            "path_params": {
              "cid": "c9999999-9999-9999-9999-999999999999"
            },
            "query_params": {
              "admin_uid": "f0000000-0000-0000-0000-000000000001"
            },
            "body": {
              "status": 1
            }
          },
          "expected_response": {
            "code": 500,
            "msg": "update failed",
            "data": false
          }
        }
      ]
    },
