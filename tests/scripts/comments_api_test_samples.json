            }
          },
          "expected_response": {
            "code": 404,
            "msg": "comment not found",
            "data": null
          }
        },
        {
          "scenario": "查询已软删除的评论",
          "request": {
            "path_params": {
              "cid": "c0000003-0000-0000-0000-000000000003"
            }
