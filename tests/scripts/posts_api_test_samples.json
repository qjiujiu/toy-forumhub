{
  "version": "1.0",
  "description": "app/api/v2/posts.py 所有接口的真实测试样例",
  "base_url": "http://localhost:8000",
  "endpoints": [
    {
      "method": "POST",
      "path": "/posts/",
      "summary": "创建帖子",
      "cases": [
        {
          "scenario": "成功创建公开已发布的帖子",
          "request": {
            "body": {
              "author_id": "221d559c-c349-497b-a40e-362717e0d1b5",
              "title": "今天天气真好",
              "content": "今天去了公园，阳光明媚，心情很好。",
              "post_status": {
                "visibility": 0,
                "publish_status": 1
              }
            }
          },
          "expected_response": {
            "code": 200,
            "msg": "success",
            "data": {
              "pid": "p0000001-0000-0000-0000-000000000001",
              "author_id": "221d559c-c349-497b-a40e-362717e0d1b5",
              "post_status": {
                "visibility": 0,
                "publish_status": 1
              },
              "post_content": {
                "pcid": "pc000001-0000-0000-0000-000000000001",
                "post_id": "p0000001-0000-0000-0000-000000000001",
                "title": "今天天气真好",
                "content": "今天去了公园，阳光明媚，心情很好。",
                "created_at": "2026-05-12T10:00:00"
              },
              "post_stats": {
                "like_count": 0,
                "comment_count": 0
              }
            }
          }
        },
        {
          "scenario": "成功创建草稿（仅作者可见）",
          "request": {
            "body": {
              "author_id": "221d559c-c349-497b-a40e-362717e0d1b5",
              "title": "未完成的想法",
              "content": "还在构思中...",
              "post_status": {
                "visibility": 1,
                "publish_status": 0
              }
            }
          },
          "expected_response": {
            "code": 200,
            "msg": "success",
            "data": {
              "pid": "p0000002-0000-0000-0000-000000000002",
              "author_id": "221d559c-c349-497b-a40e-362717e0d1b5",
              "post_status": {
                "visibility": 1,
                "publish_status": 0
              },
              "post_content": {
                "pcid": "pc000002-0000-0000-0000-000000000002",
                "post_id": "p0000002-0000-0000-0000-000000000002",
                "title": "未完成的想法",
                "content": "还在构思中...",
                "created_at": "2026-05-12T10:05:00"
              },
              "post_stats": {
                "like_count": 0,
                "comment_count": 0
              }
            }
          }
        },
        {
          "scenario": "缺少必填字段（空标题）",
          "request": {
            "body": {
              "author_id": "221d559c-c349-497b-a40e-362717e0d1b5",
              "title": "",
              "content": "正文内容",
              "post_status": {
                "visibility": 0,
                "publish_status": 1
              }
            }
          },
          "expected_response": {
            "code": 422,
            "detail": [
              {
                "loc": ["body", "title"],
                "msg": "Value error, Title and content cannot be empty",
                "type": "value_error"
              }
            ]
          }
        }
      ]
    },
    {
      "method": "GET",
      "path": "/posts/",
      "summary": "分页获取所有帖子（按创建时间倒序）",
      "cases": [
        {
          "scenario": "成功获取第一页帖子",
          "request": {
