        {
          "scenario": "空结果页（翻页超出范围）",
          "request": {
            "query_params": {
              "page": 100,
              "page_size": 10
            }
          },
          "expected_response": {
            "code": 200,
            "msg": "success",
            "data": {
              "total": 3,
              "count": 0,
              "items": []
