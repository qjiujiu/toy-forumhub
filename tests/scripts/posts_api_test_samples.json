    {
      "method": "PUT",
      "path": "/posts/content/{pid}/{uid}",
      "summary": "更新帖子内容（作者本人）",
      "cases": [
        {
          "scenario": "成功更新帖子标题和内容",
          "request": {
            "path_params": {
              "pid": "p0000001-0000-0000-0000-000000000001",
              "uid": "221d559c-c349-497b-a40e-362717e0d1b5"
            },
            "body": {
              "title": "今天天气真好（修订版）",
              "content": "补充了更多细节描述..."
            }
          },
          "expected_response": {
            "code": 200,
            "msg": "success",
            "data": {
              "pid": "p0000001-0000-0000-0000-000000000001",
              "author_id": "221d559c-c349-497b-a40e-362717e0d1b5",
              "post_status": {
                "visibility": 0,
                "publish_status": 1
              },
              "post_content": {
                "pcid": "pc000001-0000-0000-0000-000000000001",
                "post_id": "p0000001-0000-0000-0000-000000000001",
                "title": "今天天气真好（修订版）",
                "content": "补充了更多细节描述...",
                "created_at": "2026-05-12T10:00:00"
              },
              "post_stats": {
                "like_count": 5,
                "comment_count": 3
              }
            }
          }
        },
        {
          "scenario": "非作者尝试更新帖子（Forbidden）",
          "request": {
            "path_params": {
              "pid": "p0000001-0000-0000-0000-000000000001",
              "uid": "b2c3d4e5-f6a7-8901-bcde-f12345678901"
            },
            "body": {
              "title": "恶意修改标题"
            }
          },
          "expected_response": {
            "code": 403,
            "msg": "forbidden action: only the author can update this post",
            "data": null
          }
        },
        {
          "scenario": "更新不存在的帖子",
          "request": {
            "path_params": {
              "pid": "p9999999-9999-9999-9999-999999999999",
              "uid": "221d559c-c349-497b-a40e-362717e0d1b5"
            },
            "body": {
              "title": "新标题"
            }
          },
          "expected_response": {
            "code": 404,
            "msg": "pid p9999999-9999-9999-9999-999999999999 not found.",
            "data": null
